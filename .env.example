MDVIEW_HOST=mini.example.ts.net
MDVIEW_BASEPATH=/mdview
MDVIEW_BIND=127.0.0.1
MDVIEW_ALLOW_LOGIN=you@example.com
MDVIEW_ALLOW_DNSNAMES=your-device.example.ts.net.,your-phone.example.ts.net.
MDVIEW_ACCESS_LOG=/tmp/mdview.access.log
MDVIEW_REG_DIR=/Users/you/.local/share/mdview
TAILSCALE_BIN=/Applications/Tailscale.app/Contents/MacOS/Tailscale
